diff --git a/helper.c b/helper.c
new file mode 100644
index 0000000..05f6acd
--- /dev/null
+++ b/helper.c
@@ -0,0 +1,256 @@
+/*
+ * Shared helper process for local storage backends.
+ *
+ * A single "git-local-<name>" process handles both object and ref
+ * operations, matching how "git-remote-<name>" handles both refs
+ * and objects for remote repositories.
+ *
+ * Multiple helper_process structs with the same name share a single
+ * child process. The ODB and ref backends each embed their own
+ * helper_process, but helper_process_ensure() returns the same
+ * underlying connection for both.
+ */
+#include "git-compat-util.h"
+#include "gettext.h"
+#include "helper.h"
+#include "run-command.h"
+#include "sigchain.h"
+#include "strvec.h"
+#include "wrapper.h"
+
+/*
+ * Shared process state. A single child process is spawned per helper
+ * name and reused by all helper_process structs that reference it.
+ */
+struct helper_shared {
+	char *name;
+	struct child_process *child;
+	FILE *out;
+	unsigned refcount;
+
+	/* Capabilities (negotiated once, shared by all users) */
+	unsigned cap_get:1,
+		 cap_put:1,
+		 cap_have:1,
+		 cap_info:1,
+		 cap_list_objects:1,
+		 cap_odb_transaction:1,
+		 cap_read:1,
+		 cap_list:1,
+		 cap_transaction:1,
+		 cap_create:1,
+		 cap_remove:1,
+		 cap_reflog_read:1,
+		 cap_reflog_append:1,
+		 cap_reflog_exists:1,
+		 cap_reflog_delete:1;
+};
+
+/* Simple static cache of shared processes */
+static struct helper_shared **shared_helpers;
+static size_t shared_helpers_nr, shared_helpers_alloc;
+
+static struct helper_shared *find_shared(const char *name)
+{
+	for (size_t i = 0; i < shared_helpers_nr; i++)
+		if (!strcmp(shared_helpers[i]->name, name))
+			return shared_helpers[i];
+	return NULL;
+}
+
+static struct helper_shared *create_shared(const char *name, const char *gitdir)
+{
+	struct helper_shared *sh;
+	struct child_process *child;
+	struct strbuf line = STRBUF_INIT;
+	int duped;
+
+	sh = xcalloc(1, sizeof(*sh));
+	sh->name = xstrdup(name);
+	sh->refcount = 0;
+
+	child = xmalloc(sizeof(*child));
+	child_process_init(child);
+	child->in = -1;
+	child->out = -1;
+	child->err = 0;
+	child->silent_exec_failure = 1;
+	strvec_pushf(&child->args, "git-local-%s", name);
+	strvec_push(&child->args, gitdir);
+
+	if (start_command(child) < 0)
+		die(_("unable to start helper '%s'"), name);
+
+	sh->child = child;
+
+	duped = dup(child->out);
+	if (duped < 0)
+		die_errno(_("cannot dup helper output fd"));
+	sh->out = fdopen(duped, "r");
+	if (!sh->out)
+		die_errno(_("cannot fdopen helper output"));
+
+	/* Negotiate capabilities */
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(child->in, "capabilities\n", 13);
+	sigchain_pop(SIGPIPE);
+
+	while (strbuf_getline_lf(&line, sh->out) != EOF) {
+		if (!line.len)
+			break;
+		if (!strcmp(line.buf, "get"))
+			sh->cap_get = 1;
+		else if (!strcmp(line.buf, "put"))
+			sh->cap_put = 1;
+		else if (!strcmp(line.buf, "have"))
+			sh->cap_have = 1;
+		else if (!strcmp(line.buf, "info"))
+			sh->cap_info = 1;
+		else if (!strcmp(line.buf, "list-objects"))
+			sh->cap_list_objects = 1;
+		else if (!strcmp(line.buf, "odb-transaction"))
+			sh->cap_odb_transaction = 1;
+		else if (!strcmp(line.buf, "read"))
+			sh->cap_read = 1;
+		else if (!strcmp(line.buf, "list"))
+			sh->cap_list = 1;
+		else if (!strcmp(line.buf, "transaction"))
+			sh->cap_transaction = 1;
+		else if (!strcmp(line.buf, "create"))
+			sh->cap_create = 1;
+		else if (!strcmp(line.buf, "remove"))
+			sh->cap_remove = 1;
+		else if (!strcmp(line.buf, "reflog-read"))
+			sh->cap_reflog_read = 1;
+		else if (!strcmp(line.buf, "reflog-append"))
+			sh->cap_reflog_append = 1;
+		else if (!strcmp(line.buf, "reflog-exists"))
+			sh->cap_reflog_exists = 1;
+		else if (!strcmp(line.buf, "reflog-delete"))
+			sh->cap_reflog_delete = 1;
+	}
+	strbuf_release(&line);
+
+	ALLOC_GROW(shared_helpers, shared_helpers_nr + 1,
+		   shared_helpers_alloc);
+	shared_helpers[shared_helpers_nr++] = sh;
+
+	return sh;
+}
+
+static void copy_caps(struct helper_process *hp, struct helper_shared *sh)
+{
+	hp->cap_get = sh->cap_get;
+	hp->cap_put = sh->cap_put;
+	hp->cap_have = sh->cap_have;
+	hp->cap_info = sh->cap_info;
+	hp->cap_list_objects = sh->cap_list_objects;
+	hp->cap_odb_transaction = sh->cap_odb_transaction;
+	hp->cap_read = sh->cap_read;
+	hp->cap_list = sh->cap_list;
+	hp->cap_transaction = sh->cap_transaction;
+	hp->cap_create = sh->cap_create;
+	hp->cap_remove = sh->cap_remove;
+	hp->cap_reflog_read = sh->cap_reflog_read;
+	hp->cap_reflog_append = sh->cap_reflog_append;
+	hp->cap_reflog_exists = sh->cap_reflog_exists;
+	hp->cap_reflog_delete = sh->cap_reflog_delete;
+}
+
+void helper_process_init(struct helper_process *hp, const char *name,
+			 const char *gitdir)
+{
+	memset(hp, 0, sizeof(*hp));
+
+	if (strchr(name, '/'))
+		die(_("helper name '%s' must not contain '/'"), name);
+
+	hp->name = xstrdup(name);
+	hp->gitdir = xstrdup(gitdir);
+}
+
+struct helper_process *helper_process_ensure(struct helper_process *hp)
+{
+	struct helper_shared *sh;
+
+	if (hp->child)
+		return hp;
+
+	sh = find_shared(hp->name);
+	if (!sh)
+		sh = create_shared(hp->name, hp->gitdir);
+
+	hp->child = sh->child;
+	hp->out = sh->out;
+	sh->refcount++;
+	copy_caps(hp, sh);
+
+	return hp;
+}
+
+void helper_process_send(struct helper_process *hp, const char *fmt, ...)
+{
+	struct strbuf buf = STRBUF_INIT;
+	va_list ap;
+
+	helper_process_ensure(hp);
+
+	va_start(ap, fmt);
+	strbuf_vaddf(&buf, fmt, ap);
+	va_end(ap);
+
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(hp->child->in, buf.buf, buf.len);
+	sigchain_pop(SIGPIPE);
+
+	strbuf_release(&buf);
+}
+
+void helper_process_write(struct helper_process *hp, const void *buf,
+			  size_t len)
+{
+	helper_process_ensure(hp);
+
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(hp->child->in, buf, len);
+	sigchain_pop(SIGPIPE);
+}
+
+int helper_process_readline(struct helper_process *hp, struct strbuf *line)
+{
+	helper_process_ensure(hp);
+	strbuf_reset(line);
+	return strbuf_getline_lf(line, hp->out);
+}
+
+void helper_process_release(struct helper_process *hp)
+{
+	if (hp->child) {
+		struct helper_shared *sh = find_shared(hp->name);
+
+		if (sh && --sh->refcount == 0) {
+			close(sh->child->in);
+			fclose(sh->out);
+			finish_command(sh->child);
+			free(sh->child);
+
+			/* Remove from cache */
+			for (size_t i = 0; i < shared_helpers_nr; i++) {
+				if (shared_helpers[i] == sh) {
+					shared_helpers[i] =
+						shared_helpers[--shared_helpers_nr];
+					break;
+				}
+			}
+			free(sh->name);
+			free(sh);
+		}
+
+		hp->child = NULL;
+		hp->out = NULL;
+	}
+	free(hp->name);
+	hp->name = NULL;
+	free(hp->gitdir);
+	hp->gitdir = NULL;
+}
diff --git a/helper.h b/helper.h
new file mode 100644
index 0000000..91e4f08
--- /dev/null
+++ b/helper.h
@@ -0,0 +1,105 @@
+#ifndef HELPER_H
+#define HELPER_H
+
+#include "strbuf.h"
+
+struct child_process;
+
+/*
+ * Shared helper process for delegating both object and ref storage
+ * to an external process. The helper binary is discovered as
+ * "git-local-<name>" in PATH and communicates via a line-based
+ * protocol on stdin/stdout.
+ *
+ * A single helper process handles both ODB and ref operations,
+ * matching how remote helpers handle both refs (list) and objects
+ * (fetch/push) in one process. Commands use a flat namespace with
+ * distinct names per operation.
+ *
+ * ODB commands:
+ *   info <oid>             -> <type> <size> | missing
+ *   get <oid>              -> <type> <size> + data | missing
+ *   put <oid> <type> <size> + data -> <oid>
+ *   have <oid>             -> true | false
+ *   list-objects           -> <oid> <type> <size> per line, blank end
+ *   odb-transaction-begin  -> ok | error <msg>
+ *   odb-transaction-commit -> ok | error <msg>
+ *
+ * Ref commands:
+ *   read <refname>         -> <oid> | symref <target> | missing
+ *   list [<prefix>]        -> <refname> <oid|symref target>, blank end
+ *   transaction-begin      -> ok
+ *   transaction-update/create/delete/create-symref -> ok
+ *   transaction-prepare    -> ok | error <msg>
+ *   transaction-finish     -> ok | error <msg>
+ *   transaction-abort      -> ok
+ *   create                 -> ok | error <msg>
+ *   remove                 -> ok | error <msg>
+ *
+ * Reflog commands (native reflog line format):
+ *   reflog-read <refname>  -> lines in git reflog format, blank end
+ *     Each line: <old-oid> SP <new-oid> SP <name> SP LT <email> GT SP <ts> SP <tz> TAB <msg>
+ *   reflog-append <refname> <old-oid> <new-oid> <name> <email> <ts> <tz> <msg>
+ *                          -> ok | error <msg>
+ *   reflog-exists <refname> -> true | false
+ *   reflog-delete <refname> -> ok | error <msg>
+ */
+struct helper_process {
+	struct child_process *child;
+	FILE *out;
+	char *name;
+	char *gitdir;
+
+	unsigned cap_get:1,
+		 cap_put:1,
+		 cap_have:1,
+		 cap_info:1,
+		 cap_list_objects:1,
+		 cap_odb_transaction:1,
+		 cap_read:1,
+		 cap_list:1,
+		 cap_transaction:1,
+		 cap_create:1,
+		 cap_remove:1,
+		 cap_reflog_read:1,
+		 cap_reflog_append:1,
+		 cap_reflog_exists:1,
+		 cap_reflog_delete:1;
+};
+
+/*
+ * Get or lazily start the helper process. The helper is spawned as
+ * "git-local-<name>" with <gitdir> as its sole argument. Capabilities
+ * are negotiated on first call. Returns the helper process.
+ */
+struct helper_process *helper_process_ensure(struct helper_process *hp);
+
+/*
+ * Send a formatted command to the helper.
+ */
+void helper_process_send(struct helper_process *hp, const char *fmt, ...);
+
+/*
+ * Send raw bytes to the helper (for binary data after a text header).
+ */
+void helper_process_write(struct helper_process *hp, const void *buf,
+			  size_t len);
+
+/*
+ * Read one line from the helper. Returns EOF on end of stream.
+ */
+int helper_process_readline(struct helper_process *hp, struct strbuf *line);
+
+/*
+ * Release the helper process and all associated resources.
+ */
+void helper_process_release(struct helper_process *hp);
+
+/*
+ * Initialize a helper_process struct with the given name and gitdir.
+ * Does not start the process; that happens lazily on first use.
+ */
+void helper_process_init(struct helper_process *hp, const char *name,
+			 const char *gitdir);
+
+#endif
