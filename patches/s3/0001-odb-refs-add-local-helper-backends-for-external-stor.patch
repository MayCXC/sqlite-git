+int parse_reflog_line(const struct git_hash_algo *algop, char *buf,
+		      struct object_id *ooid, struct object_id *noid,
+		      const char **committer, timestamp_t *timestamp,
+		      int *tz, const char **msg)
+{
+	const char *p = buf;
+	char *email_end, *ts_end;
+
+	if (parse_oid_hex_algop(p, ooid, &p, algop) || *p++ != ' ' ||
+	    parse_oid_hex_algop(p, noid, &p, algop) || *p++ != ' ')
+		return -1;
+
+	*committer = p;
+
+	email_end = strchr(p, '>');
+	if (!email_end || email_end[1] != ' ')
+		return -1;
+
+	email_end[1] = '\0';
+	*timestamp = parse_timestamp(email_end + 2, &ts_end, 10);
+	if (!ts_end || ts_end[0] != ' ')
+		return -1;
+
+	*tz = strtol(ts_end + 1, &ts_end, 10);
+
+	if (*ts_end == '\t')
+		*msg = ts_end + 1;
+	else
+		*msg = "";
+
+	return 0;
+}
