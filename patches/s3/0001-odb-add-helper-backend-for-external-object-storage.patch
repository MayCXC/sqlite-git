+. ./test-lib.sh
+
+# Write a minimal ODB helper that stores objects as flat files.
+# The helper name is "test", so git discovers it as "git-odb-test".
+write_helper () {
+	write_script "$1" <<-'EOF'
+	OBJDIR="$1/helper-objects"
+	mkdir -p "$OBJDIR"
+	while IFS= read -r line; do
+		case "$line" in
+		capabilities)
+			printf '%s\n' get put have info list ""
+			;;
+		info\ *)
+			oid="${line#info }"
+			if test -f "$OBJDIR/$oid.meta"; then
+				cat "$OBJDIR/$oid.meta"
+			else
+				echo missing
+			fi
+			;;
+		get\ *)
+			oid="${line#get }"
+			if test -f "$OBJDIR/$oid.meta"; then
+				cat "$OBJDIR/$oid.meta"
+				cat "$OBJDIR/$oid"
+			else
+				echo missing
+			fi
+			;;
+		put\ *)
+			# put <oid> <type> <size>
+			oid=$(echo "$line" | cut -d' ' -f2)
+			type=$(echo "$line" | cut -d' ' -f3)
+			size=$(echo "$line" | cut -d' ' -f4)
+			printf '%s %s\n' "$type" "$size" >"$OBJDIR/$oid.meta"
+			head -c "$size" >"$OBJDIR/$oid"
+			echo "$oid"
+			;;
+		have\ *)
+			oid="${line#have }"
+			if test -f "$OBJDIR/$oid.meta"; then
+				echo true
+			else
+				echo false
+			fi
+			;;
+		list)
+			for meta in "$OBJDIR"/*.meta; do
+				test -f "$meta" || continue
+				oid=$(basename "$meta" .meta)
+				read -r type size <"$meta"
+				printf '%s %s %s\n' "$oid" "$type" "$size"
+			done
+			echo ""
+			;;
+		"")
+			;;
+		esac
+	done
+	EOF
+}
+
+test_expect_success 'setup helper in PATH' '
+	mkdir helper-bin &&
+	write_helper helper-bin/git-odb-test &&
+	PATH="$PWD/helper-bin:$PATH" &&
+	export PATH
+'
+
+# Helper to create a repo with the helper backend configured.
+# Uses --file to write config directly, bypassing format checks.
+setup_helper_repo () {
+	git init "$1" &&
+	git config --file "$1/.git/config" core.repositoryformatversion 1 &&
+	git config --file "$1/.git/config" extensions.objectStorage "helper://test"
+}
+
+test_expect_success 'config: extensions.objectStorage = helper://test is accepted' '
+	test_when_finished "rm -rf repo" &&
+	setup_helper_repo repo &&
+	git -C repo rev-parse --git-dir
+'
+
+test_expect_success 'hash-object: write through helper backend' '
+	test_when_finished "rm -rf repo" &&
+	setup_helper_repo repo &&
+	echo "hello world" >repo/file &&
+	oid=$(git -C repo hash-object -w --stdin <repo/file) &&
+	test -n "$oid" &&
+	test -f repo/.git/objects/helper-objects/$oid
+'
+
+test_expect_success 'cat-file: read through helper backend' '
+	test_when_finished "rm -rf repo" &&
+	setup_helper_repo repo &&
+	echo "hello world" >repo/file &&
+	oid=$(git -C repo hash-object -w --stdin <repo/file) &&
+	echo "hello world" >expect &&
+	git -C repo cat-file blob $oid >actual &&
+	test_cmp expect actual
+'
+
+test_expect_success 'cat-file -t: type through helper backend' '
+	test_when_finished "rm -rf repo" &&
+	setup_helper_repo repo &&
+	echo "hello world" >repo/file &&
+	oid=$(git -C repo hash-object -w --stdin <repo/file) &&
+	echo blob >expect &&
+	git -C repo cat-file -t $oid >actual &&
+	test_cmp expect actual
+'
+
+test_done
