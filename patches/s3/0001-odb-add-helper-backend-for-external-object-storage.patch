--- /dev/null
+++ b/t/t0620-odb-helper.sh
@@ -0,0 +1,121 @@
+#!/bin/sh
+
+test_description='ODB helper backend basics'
+
+GIT_TEST_DEFAULT_INITIAL_BRANCH_NAME=main
+export GIT_TEST_DEFAULT_INITIAL_BRANCH_NAME
