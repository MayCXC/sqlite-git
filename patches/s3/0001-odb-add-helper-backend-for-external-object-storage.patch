--- /dev/null
+++ b/odb/source-helper.c
@@ -0,0 +1,389 @@
+/*
+ * ODB helper: delegate object storage to an external process.
+ *
+ * Follows the same pattern as transport-helper.c for remote helpers
+ * and credential.c for credential helpers. The helper binary is
+ * discovered as "git-odb-<name>" in PATH and communicates via a
+ * line-based protocol on stdin/stdout.
+ */
+#include "git-compat-util.h"
+#include "gettext.h"
+#include "hex.h"
+#include "object.h"
+#include "object-file.h"
+#include "odb/source-helper.h"
+#include "repository.h"
+#include "run-command.h"
+#include "sigchain.h"
+#include "strbuf.h"
+#include "strvec.h"
+#include "wrapper.h"
+
+static struct child_process *get_helper(struct odb_source_helper *src)
+{
+	struct child_process *helper;
+	struct strbuf line = STRBUF_INIT;
+	int duped;
+
+	if (src->helper)
+		return src->helper;
+
+	helper = xmalloc(sizeof(*helper));
+	child_process_init(helper);
+	helper->in = -1;
+	helper->out = -1;
+	helper->err = 0;
+	helper->silent_exec_failure = 1;
+	strvec_pushf(&helper->args, "git-odb-%s", src->helper_name);
+	strvec_push(&helper->args, src->base.path);
+
+	if (start_command(helper) < 0)
+		die(_("unable to start odb helper '%s'"), src->helper_name);
+
+	src->helper = helper;
+
+	duped = dup(helper->out);
+	if (duped < 0)
+		die_errno(_("cannot dup odb helper output fd"));
+	src->helper_out = fdopen(duped, "r");
+	if (!src->helper_out)
+		die_errno(_("cannot fdopen odb helper output"));
+
+	/* Negotiate capabilities */
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(helper->in, "capabilities\n", 13);
+	sigchain_pop(SIGPIPE);
+
+	while (strbuf_getline_lf(&line, src->helper_out) != EOF) {
+		if (!line.len)
+			break;
+		if (!strcmp(line.buf, "get"))
+			src->cap_get = 1;
+		else if (!strcmp(line.buf, "put"))
+			src->cap_put = 1;
+		else if (!strcmp(line.buf, "have"))
+			src->cap_have = 1;
+		else if (!strcmp(line.buf, "info"))
+			src->cap_info = 1;
+		else if (!strcmp(line.buf, "list"))
+			src->cap_list = 1;
+	}
+	strbuf_release(&line);
+
+	return helper;
+}
+
+static void helper_send(struct odb_source_helper *src, const char *fmt, ...)
+{
+	struct child_process *h = get_helper(src);
+	struct strbuf buf = STRBUF_INIT;
+	va_list ap;
+
+	va_start(ap, fmt);
+	strbuf_vaddf(&buf, fmt, ap);
+	va_end(ap);
+
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(h->in, buf.buf, buf.len);
+	sigchain_pop(SIGPIPE);
+
+	strbuf_release(&buf);
+}
+
+static int helper_readline(struct odb_source_helper *src, struct strbuf *line)
+{
+	get_helper(src);
+	strbuf_reset(line);
+	return strbuf_getline_lf(line, src->helper_out);
+}
+
+/* ---- odb_source callbacks ---- */
+
+static void helper_free(struct odb_source *source)
+{
+	struct odb_source_helper *src =
+		container_of(source, struct odb_source_helper, base);
+
+	if (src->helper) {
+		close(src->helper->in);
+		fclose(src->helper_out);
+		finish_command(src->helper);
+		free(src->helper);
+	}
+	free(src->helper_name);
+	odb_source_release(&src->base);
+	free(src);
+}
+
+static void helper_close(struct odb_source *source UNUSED)
+{
+	/* Keep helper process alive for reuse within this session. */
+}
+
+static void helper_reprepare(struct odb_source *source UNUSED)
+{
+	/* The helper manages its own caches. Nothing to do here. */
+}
+
+static int helper_read_object_info(struct odb_source *source,
+				   const struct object_id *oid,
+				   struct object_info *oi,
+				   enum object_info_flags flags UNUSED)
+{
+	struct odb_source_helper *src =
+		container_of(source, struct odb_source_helper, base);
+	struct strbuf line = STRBUF_INIT;
+	char hex[GIT_MAX_HEXSZ + 1];
+	char type_str[32];
+	unsigned long size;
+	enum object_type type;
+	int want_content;
+	int ret = -1;
+
+	/* Ensure the helper process is started and capabilities negotiated */
+	get_helper(src);
+
+	oid_to_hex_r(hex, oid);
+	want_content = oi->contentp != NULL;
+
+	/*
+	 * Use "info" for metadata-only requests and "get" when the
+	 * caller also wants the object content. This avoids sending
+	 * data over the pipe when only type and size are needed.
+	 */
+	if (want_content && src->cap_get)
+		helper_send(src, "get %s\n", hex);
+	else if (src->cap_info)
+		helper_send(src, "info %s\n", hex);
+	else if (src->cap_get)
+		helper_send(src, "get %s\n", hex);
+	else
+		goto out;
+
+	if (helper_readline(src, &line) == EOF)
+		goto out;
+
+	if (!strcmp(line.buf, "missing"))
+		goto out;
+
+	/* Parse "<type> <size>" */
+	if (sscanf(line.buf, "%31s %lu", type_str, &size) != 2)
+		goto out;
+
+	type = type_from_string(type_str);
+	if (oi->typep)
+		*(oi->typep) = type;
+	if (oi->sizep)
+		*(oi->sizep) = size;
+
+	if (want_content && src->cap_get) {
+		size_t got;
+
+		*oi->contentp = xmalloc(size);
+		/*
+		 * Must use fread rather than read_in_full on
+		 * fileno(helper_out) because strbuf_getline may have
+		 * buffered data in the FILE*.
+		 */
+		got = fread(*oi->contentp, 1, size, src->helper_out);
+		if (got != size) {
+			free(*oi->contentp);
+			*oi->contentp = NULL;
+			goto out;
+		}
+	}
+
+	ret = 0;
+out:
+	strbuf_release(&line);
+	return ret;
+}
+
+static int helper_read_object_stream(struct odb_read_stream **out UNUSED,
+				     struct odb_source *source UNUSED,
+				     const struct object_id *oid UNUSED)
+{
+	/* Streaming reads are not supported via the helper protocol. */
+	return -1;
+}
+
+static int helper_for_each_object(struct odb_source *source,
+				  const struct object_info *request,
+				  odb_for_each_object_cb cb,
+				  void *cb_data,
+				  unsigned flags UNUSED)
+{
+	struct odb_source_helper *src =
+		container_of(source, struct odb_source_helper, base);
+	struct strbuf line = STRBUF_INIT;
+	int ret = 0;
+
+	get_helper(src);
+
+	if (!src->cap_list)
+		return 0;
+
+	helper_send(src, "list\n");
+
+	while (helper_readline(src, &line) != EOF) {
+		char oid_hex[GIT_MAX_HEXSZ + 1];
+		char type_str[32];
+		unsigned long size;
+		struct object_id oid;
+		struct object_info oi = OBJECT_INFO_INIT;
+		enum object_type type;
+
+		if (!line.len)
+			break;
+
+		if (sscanf(line.buf, "%s %31s %lu",
+			   oid_hex, type_str, &size) != 3)
+			continue;
+
+		if (get_oid_hex_any(oid_hex, &oid) == GIT_HASH_UNKNOWN)
+			continue;
+
+		type = type_from_string(type_str);
+		if (request && request->typep)
+			oi.typep = &type;
+		if (request && request->sizep)
+			oi.sizep = &size;
+
+		ret = cb(&oid, &oi, cb_data);
+		if (ret)
+			break;
+	}
+	strbuf_release(&line);
+	return ret;
+}
+
+static int helper_freshen_object(struct odb_source *source,
+				 const struct object_id *oid)
+{
+	struct odb_source_helper *src =
+		container_of(source, struct odb_source_helper, base);
+	struct strbuf line = STRBUF_INIT;
+	char hex[GIT_MAX_HEXSZ + 1];
+	int exists;
+
+	get_helper(src);
+
+	if (!src->cap_have)
+		return 0;
+
+	oid_to_hex_r(hex, oid);
+	helper_send(src, "have %s\n", hex);
+
+	if (helper_readline(src, &line) == EOF) {
+		strbuf_release(&line);
+		return 0;
+	}
+	exists = !strcmp(line.buf, "true");
+	strbuf_release(&line);
+	return exists;
+}
+
+static int helper_write_object(struct odb_source *source,
+			       const void *buf, unsigned long len,
+			       enum object_type type,
+			       struct object_id *oid,
+			       struct object_id *compat_oid,
+			       unsigned flags UNUSED)
+{
+	struct odb_source_helper *src =
+		container_of(source, struct odb_source_helper, base);
+	struct strbuf line = STRBUF_INIT;
+	char hex[GIT_MAX_HEXSZ + 1];
+
+	/* Ensure the helper process is started and capabilities negotiated */
+	get_helper(src);
+
+	if (!src->cap_put)
+		return -1;
+
+	/* Compute OID locally so the helper can store it directly */
+	hash_object_file(src->base.odb->repo->hash_algo, buf, len, type, oid);
+	oid_to_hex_r(hex, oid);
+
+	helper_send(src, "put %s %s %lu\n", hex, type_name(type), len);
+
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(get_helper(src)->in, buf, len);
+	sigchain_pop(SIGPIPE);
+
+	if (helper_readline(src, &line) == EOF) {
+		strbuf_release(&line);
+		return -1;
+	}
+	strbuf_release(&line);
+
+	if (compat_oid)
+		oidcpy(compat_oid, oid);
+	return 0;
+}
+
+static int helper_write_object_stream(struct odb_source *source UNUSED,
+				      struct odb_write_stream *stream UNUSED,
+				      size_t len UNUSED,
+				      struct object_id *oid UNUSED)
+{
+	return -1;
+}
+
+static int helper_begin_transaction(struct odb_source *source UNUSED,
+				    struct odb_transaction **out UNUSED)
+{
+	return -1;
+}
+
+static int helper_read_alternates(struct odb_source *source UNUSED,
+				  struct strvec *out UNUSED)
+{
+	return 0;
+}
+
+static int helper_write_alternate(struct odb_source *source UNUSED,
+				  const char *alternate UNUSED)
+{
+	return -1;
+}
+
+/* ---- Constructor ---- */
+
+struct odb_source_helper *odb_source_helper_new(struct object_database *odb,
+						const char *helper_name,
+						const char *path,
+						bool local)
+{
+	struct odb_source_helper *src;
+
+	CALLOC_ARRAY(src, 1);
+	odb_source_init(&src->base, odb, ODB_STORAGE_FORMAT_HELPER, path, local);
+	src->helper_name = xstrdup(helper_name);
+	src->base.free = helper_free;
+	src->base.close = helper_close;
+	src->base.reprepare = helper_reprepare;
+	src->base.read_object_info = helper_read_object_info;
+	src->base.read_object_stream = helper_read_object_stream;
+	src->base.for_each_object = helper_for_each_object;
+	src->base.freshen_object = helper_freshen_object;
+	src->base.write_object = helper_write_object;
+	src->base.write_object_stream = helper_write_object_stream;
+	src->base.begin_transaction = helper_begin_transaction;
+	src->base.read_alternates = helper_read_alternates;
+	src->base.write_alternate = helper_write_alternate;
+	return src;
+}
+
+struct odb_source *odb_source_helper_new_base(struct object_database *odb,
+					      const char *path,
+					      bool local)
+{
+	const char *payload = odb->repo->odb_storage_payload;
+
+	if (!payload || !*payload)
+		die(_("odb helper backend requires a helper name in "
+		      "extensions.objectStorage (e.g. helper://sqlite)"));
+
+	return &odb_source_helper_new(odb, payload, path, local)->base;
+}
