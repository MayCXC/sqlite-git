From 47a3587478b5d653e7813f3550bb79e67e3616aa Mon Sep 17 00:00:00 2001
From: Aaron Paterson <apaterson@pm.me>
Date: Tue, 17 Mar 2026 19:41:18 +0000
Subject: [PATCH 2/2] refs: extract parse_reflog_line() for shared use

Extract the reflog line parsing logic from show_one_reflog_ent()
in refs/files-backend.c into a shared parse_reflog_line() function
declared in refs/refs-internal.h and defined in refs.c.

Both the files backend and the local helper backend need to parse
the native reflog format:

  <old-oid> SP <new-oid> SP <name> SP LT <email> GT SP <ts> SP <tz> TAB <msg>

Previously, show_one_reflog_ent() contained this parsing inline.
The helper backend duplicated it with sscanf, which broke on author
names containing spaces (e.g. "John Doe <john@x.com>").

The shared function uses parse_oid_hex_algop() for OIDs, strchr('>')
for the email boundary, and parse_timestamp()/strtol() for the
timestamp and timezone. It modifies the buffer in place (inserting
a NUL after '>') matching the original show_one_reflog_ent()
behavior.

show_one_reflog_ent() now delegates to parse_reflog_line() and
only adds the trailing-LF check specific to file-based reflogs.

Signed-off-by: Aaron Willoughby <aaron@omniband.org>
---
 refs/files-backend.c | 32 +++++++++++---------------------
 refs/refs-internal.h | 15 +++++++++++++++
 2 files changed, 26 insertions(+), 21 deletions(-)

diff --git a/refs/files-backend.c b/refs/files-backend.c
index 7ce0d57..325f6ce 100644
--- a/refs/files-backend.c
+++ b/refs/files-backend.c
@@ -2187,30 +2187,20 @@ static int show_one_reflog_ent(struct files_ref_store *refs,
 			       each_reflog_ent_fn fn, void *cb_data)
 {
 	struct object_id ooid, noid;
-	char *email_end, *message;
+	const char *committer, *message;
 	timestamp_t timestamp;
 	int tz;
-	const char *p = sb->buf;
-
-	/* old SP new SP name <email> SP time TAB msg LF */
-	if (!sb->len || sb->buf[sb->len - 1] != '\n' ||
-	    parse_oid_hex_algop(p, &ooid, &p, refs->base.repo->hash_algo) || *p++ != ' ' ||
-	    parse_oid_hex_algop(p, &noid, &p, refs->base.repo->hash_algo) || *p++ != ' ' ||
-	    !(email_end = strchr(p, '>')) ||
-	    email_end[1] != ' ' ||
-	    !(timestamp = parse_timestamp(email_end + 2, &message, 10)) ||
-	    !message || message[0] != ' ' ||
-	    (message[1] != '+' && message[1] != '-') ||
-	    !isdigit(message[2]) || !isdigit(message[3]) ||
-	    !isdigit(message[4]) || !isdigit(message[5]))
+
+	if (!sb->len || sb->buf[sb->len - 1] != '\n')
 		return 0; /* corrupt? */
-	email_end[1] = '\0';
-	tz = strtol(message + 1, NULL, 10);
-	if (message[6] != '\t')
-		message += 6;
-	else
-		message += 7;
-	return fn(refname, &ooid, &noid, p, timestamp, tz, message, cb_data);
+
+	if (parse_reflog_line(refs->base.repo->hash_algo, sb->buf,
+			      &ooid, &noid, &committer,
+			      &timestamp, &tz, &message))
+		return 0; /* corrupt? */
+
+	return fn(refname, &ooid, &noid, committer, timestamp, tz,
+		  message, cb_data);
 }
 
 static char *find_beginning_of_line(char *bob, char *scan)
diff --git a/refs/refs-internal.h b/refs/refs-internal.h
index d79e35f..9fb012c 100644
--- a/refs/refs-internal.h
+++ b/refs/refs-internal.h
@@ -612,6 +612,21 @@ int parse_loose_ref_contents(const struct git_hash_algo *algop,
 			     struct strbuf *referent, unsigned int *type,
 			     const char **trailing, int *failure_errno);
 
+/*
+ * Parse a single reflog line in the standard format:
+ *   <old-oid> SP <new-oid> SP <name> SP LT <email> GT SP <timestamp> SP <tz> TAB <msg>
+ *
+ * On success, populate ooid, noid, sets *committer to point into buf
+ * at the committer identity (up to and including '>'), sets *timestamp,
+ * *tz, and *msg, and returns 0. On parse failure, returns -1.
+ *
+ * Note: this modifies buf in place (inserts a NUL after '>').
+ */
+int parse_reflog_line(const struct git_hash_algo *algop, char *buf,
+		      struct object_id *ooid, struct object_id *noid,
+		      const char **committer, timestamp_t *timestamp,
+		      int *tz, const char **msg);
+
 /*
  * Fill in the generic part of refs and add it to our collection of
  * reference stores.
