-static int helper_for_each_reflog_ent(struct ref_store *ref_store UNUSED,
-				      const char *refname UNUSED,
-				      each_reflog_ent_fn fn UNUSED,
-				      void *cb_data UNUSED)
+/* ---- Reflog operations ---- */
+
+static int helper_for_each_reflog_ent(struct ref_store *ref_store,
+				      const char *refname,
+				      each_reflog_ent_fn fn,
+				      void *cb_data)
 {
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct helper_process *hp = &refs->hp;
+	struct strbuf line = STRBUF_INIT;
+
+	helper_process_ensure(hp);
+
+	if (!hp->cap_reflog_read)
+		return 0;
+
+	helper_process_send(hp, "reflog-read %s\n", refname);
+
+	while (helper_process_readline(hp, &line) != EOF) {
+		struct object_id old_oid, new_oid;
+		char old_hex[GIT_MAX_HEXSZ + 1], new_hex[GIT_MAX_HEXSZ + 1];
+		char author[256];
+		timestamp_t timestamp;
+		int tz;
+		char msg[4096];
+		int ret;
+
+		if (!line.len)
+			break;
+
+		/* <old-oid> <new-oid> <author> <timestamp> <tz> <msg> */
+		if (sscanf(line.buf, "%64s %64s %255s %"PRItime" %d %4095[^\n]",
+			   old_hex, new_hex, author, &timestamp, &tz,
+			   msg) < 5)
+			continue;
+
+		if (get_oid_hex_any(old_hex, &old_oid) == GIT_HASH_UNKNOWN ||
+		    get_oid_hex_any(new_hex, &new_oid) == GIT_HASH_UNKNOWN)
+			continue;
+
+		ret = fn(refname, &old_oid, &new_oid, author,
+			 timestamp, tz, msg, cb_data);
+		if (ret) {
+			strbuf_release(&line);
+			return ret;
+		}
+	}
+	strbuf_release(&line);
 	return 0;
 }
 
 static int helper_for_each_reflog_ent_reverse(
-		struct ref_store *ref_store UNUSED,
-		const char *refname UNUSED,
-		each_reflog_ent_fn fn UNUSED,
-		void *cb_data UNUSED)
+		struct ref_store *ref_store,
+		const char *refname,
+		each_reflog_ent_fn fn,
+		void *cb_data)
 {
+	/*
+	 * Collect all entries and replay in reverse. Not efficient
+	 * for large reflogs, but correct.
+	 */
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct helper_process *hp = &refs->hp;
+	struct strbuf line = STRBUF_INIT;
+	struct strbuf *entries = NULL;
+	size_t nr = 0, alloc = 0;
+
+	helper_process_ensure(hp);
+
+	if (!hp->cap_reflog_read)
+		return 0;
+
+	helper_process_send(hp, "reflog-read %s\n", refname);
+
+	while (helper_process_readline(hp, &line) != EOF) {
+		if (!line.len)
+			break;
+		ALLOC_GROW(entries, nr + 1, alloc);
+		strbuf_init(&entries[nr], line.len);
+		strbuf_addbuf(&entries[nr], &line);
+		nr++;
+	}
+	strbuf_release(&line);
+
+	for (size_t i = nr; i > 0; i--) {
+		struct object_id old_oid, new_oid;
+		char old_hex[GIT_MAX_HEXSZ + 1], new_hex[GIT_MAX_HEXSZ + 1];
+		char author[256];
+		timestamp_t timestamp;
+		int tz;
+		char msg[4096];
+		int ret;
+
+		msg[0] = '\0';
+		if (sscanf(entries[i - 1].buf,
+			   "%64s %64s %255s %"PRItime" %d %4095[^\n]",
+			   old_hex, new_hex, author, &timestamp, &tz,
+			   msg) < 5)
+			continue;
+
+		if (get_oid_hex_any(old_hex, &old_oid) == GIT_HASH_UNKNOWN ||
+		    get_oid_hex_any(new_hex, &new_oid) == GIT_HASH_UNKNOWN)
+			continue;
+
+		ret = fn(refname, &old_oid, &new_oid, author,
+			 timestamp, tz, msg, cb_data);
+		if (ret) {
+			for (size_t j = 0; j < nr; j++)
+				strbuf_release(&entries[j]);
+			free(entries);
+			return ret;
+		}
+	}
+
+	for (size_t j = 0; j < nr; j++)
+		strbuf_release(&entries[j]);
+	free(entries);
 	return 0;
 }
 
