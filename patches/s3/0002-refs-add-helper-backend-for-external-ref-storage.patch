diff --git a/refs/helper-backend.h b/refs/helper-backend.h
new file mode 100644
index 0000000..68b14ef
--- /dev/null
+++ b/refs/helper-backend.h
@@ -0,0 +1,58 @@
+#ifndef REFS_HELPER_BACKEND_H
+#define REFS_HELPER_BACKEND_H
+
+/*
+ * Ref helper backend: delegate ref storage to an external process.
+ *
+ * Follows the same pattern as the ODB helper backend in odb/source-helper.c
+ * and transport helpers in transport-helper.c. The helper binary is
+ * discovered as "git-ref-<name>" in PATH and communicates via a
+ * line-based protocol on stdin/stdout.
+ *
+ * Configuration:
+ *   [extensions]
+ *     refStorage = helper://sqlite
+ *
+ * Protocol:
+ *
+ *   -> capabilities\n
+ *   <- read\n
+ *   <- list\n
+ *   <- transaction\n
+ *   <- create\n
+ *   <- \n
+ *
+ *   -> read <refname>\n
+ *   <- <hex-oid>\n                  (regular ref)
+ *   <- symref <target>\n           (symbolic ref)
+ *   <- missing\n                   (ref does not exist)
+ *
+ *   -> list [<prefix>]\n
+ *   <- <refname> <hex-oid>\n       (regular ref, repeated)
+ *   <- <refname> symref <target>\n (symbolic ref)
+ *   <- \n                          (end of list)
+ *
+ *   -> transaction-begin\n
+ *   <- ok\n
+ *   -> transaction-update <refname> <new-oid> <old-oid> [<msg>]\n
+ *   <- ok\n
+ *   -> transaction-create <refname> <new-oid> [<msg>]\n
+ *   <- ok\n
+ *   -> transaction-delete <refname> <old-oid> [<msg>]\n
+ *   <- ok\n
+ *   -> transaction-create-symref <refname> <target> [<msg>]\n
+ *   <- ok\n
+ *   -> transaction-prepare\n
+ *   <- ok\n | error <msg>\n
+ *   -> transaction-finish\n
+ *   <- ok\n | error <msg>\n
+ *   -> transaction-abort\n
+ *   <- ok\n
+ *
+ *   -> create\n
+ *   <- ok\n | error <msg>\n
+ */
+
+extern struct ref_storage_be refs_be_helper;
+
+#endif
