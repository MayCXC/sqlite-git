+/*
+ * Ref helper backend: delegate ref storage to an external process.
+ *
+ * Follows the same pattern as odb/source-helper.c for object storage
+ * and transport-helper.c for remote helpers. The helper binary is
+ * discovered as "git-ref-<name>" in PATH and communicates via a
+ * line-based protocol on stdin/stdout.
+ */
+#include "../git-compat-util.h"
+#include "../gettext.h"
+#include "../hash.h"
+#include "../hex.h"
+#include "../object.h"
+#include "../repository.h"
+#include "../run-command.h"
+#include "../sigchain.h"
+#include "../strbuf.h"
+#include "../strvec.h"
+#include "../wrapper.h"
+#include "refs-internal.h"
+#include "helper-backend.h"
+
+struct helper_ref_store {
+	struct ref_store base;
+	struct child_process *helper;
+	FILE *helper_out;
+	char *helper_name;
+	unsigned int store_flags;
+
+	unsigned cap_read:1,
+		 cap_list:1,
+		 cap_transaction:1,
+		 cap_create:1;
+};
+
+static struct child_process *get_ref_helper(struct helper_ref_store *refs)
+{
+	struct child_process *helper;
+	struct strbuf line = STRBUF_INIT;
+	int duped;
+
+	if (refs->helper)
+		return refs->helper;
+
+	helper = xmalloc(sizeof(*helper));
+	child_process_init(helper);
+	helper->in = -1;
+	helper->out = -1;
+	helper->err = 0;
+	helper->silent_exec_failure = 1;
+	strvec_pushf(&helper->args, "git-ref-%s", refs->helper_name);
+	strvec_push(&helper->args, refs->base.gitdir);
+
+	if (start_command(helper) < 0)
+		die(_("unable to start ref helper '%s'"), refs->helper_name);
+
+	refs->helper = helper;
+
+	duped = dup(helper->out);
+	if (duped < 0)
+		die_errno(_("cannot dup ref helper output fd"));
+	refs->helper_out = fdopen(duped, "r");
+	if (!refs->helper_out)
+		die_errno(_("cannot fdopen ref helper output"));
+
+	/* Negotiate capabilities */
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(helper->in, "capabilities\n", 13);
+	sigchain_pop(SIGPIPE);
+
+	while (strbuf_getline_lf(&line, refs->helper_out) != EOF) {
+		if (!line.len)
+			break;
+		if (!strcmp(line.buf, "read"))
+			refs->cap_read = 1;
+		else if (!strcmp(line.buf, "list"))
+			refs->cap_list = 1;
+		else if (!strcmp(line.buf, "transaction"))
+			refs->cap_transaction = 1;
+		else if (!strcmp(line.buf, "create"))
+			refs->cap_create = 1;
+	}
+	strbuf_release(&line);
+
+	return helper;
+}
+
+static void ref_helper_send(struct helper_ref_store *refs,
+			    const char *fmt, ...)
+{
+	struct child_process *h = get_ref_helper(refs);
+	struct strbuf buf = STRBUF_INIT;
+	va_list ap;
+
+	va_start(ap, fmt);
+	strbuf_vaddf(&buf, fmt, ap);
+	va_end(ap);
+
+	sigchain_push(SIGPIPE, SIG_IGN);
+	write_in_full(h->in, buf.buf, buf.len);
+	sigchain_pop(SIGPIPE);
+
+	strbuf_release(&buf);
+}
+
+static int ref_helper_readline(struct helper_ref_store *refs,
+			       struct strbuf *line)
+{
+	get_ref_helper(refs);
+	strbuf_reset(line);
+	return strbuf_getline_lf(line, refs->helper_out);
+}
+
+/* ---- ref_storage_be callbacks ---- */
+
+static struct helper_ref_store *helper_downcast(struct ref_store *ref_store)
+{
+	if (ref_store->be != &refs_be_helper)
+		BUG("ref_store is type \"%s\" not \"helper\"",
+		    ref_store->be->name);
+	return (struct helper_ref_store *)ref_store;
+}
+
+static struct ref_store *helper_ref_store_init(struct repository *repo,
+					       const char *payload,
+					       const char *gitdir,
+					       unsigned int flags)
+{
+	struct helper_ref_store *refs = xcalloc(1, sizeof(*refs));
+
+	if (!payload || !*payload)
+		die(_("ref helper backend requires a helper name in "
+		      "extensions.refStorage (e.g. helper://sqlite)"));
+
+	base_ref_store_init(&refs->base, repo, gitdir, &refs_be_helper);
+	refs->store_flags = flags;
+	refs->helper_name = xstrdup(payload);
+	return &refs->base;
+}
+
+static void helper_ref_store_release(struct ref_store *ref_store)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+
+	if (refs->helper) {
+		close(refs->helper->in);
+		fclose(refs->helper_out);
+		finish_command(refs->helper);
+		free(refs->helper);
+	}
+	free(refs->helper_name);
+}
+
+static int helper_create_on_disk(struct ref_store *ref_store,
+				 int flags UNUSED,
+				 struct strbuf *err)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct strbuf line = STRBUF_INIT;
+
+	get_ref_helper(refs);
+
+	if (!refs->cap_create) {
+		strbuf_addstr(err, "ref helper does not support create");
+		return -1;
+	}
+
+	ref_helper_send(refs, "create\n");
+	if (ref_helper_readline(refs, &line) == EOF) {
+		strbuf_addstr(err, "ref helper EOF during create");
+		strbuf_release(&line);
+		return -1;
+	}
+
+	if (starts_with(line.buf, "error ")) {
+		strbuf_addstr(err, line.buf + 6);
+		strbuf_release(&line);
+		return -1;
+	}
+
+	strbuf_release(&line);
+	return 0;
+}
+
+static int helper_remove_on_disk(struct ref_store *ref_store UNUSED,
+				 struct strbuf *err)
+{
+	strbuf_addstr(err, "ref helper does not support remove_on_disk");
+	return -1;
+}
+
+/* ---- Read operations ---- */
+
+static int helper_read_raw_ref(struct ref_store *ref_store,
+			       const char *refname,
+			       struct object_id *oid,
+			       struct strbuf *referent,
+			       unsigned int *type,
+			       int *failure_errno)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct strbuf line = STRBUF_INIT;
+
+	get_ref_helper(refs);
+
+	if (!refs->cap_read) {
+		*failure_errno = ENOENT;
+		return -1;
+	}
+
+	ref_helper_send(refs, "read %s\n", refname);
+	if (ref_helper_readline(refs, &line) == EOF) {
+		*failure_errno = ENOENT;
+		strbuf_release(&line);
+		return -1;
+	}
+
+	if (!strcmp(line.buf, "missing")) {
+		*failure_errno = ENOENT;
+		strbuf_release(&line);
+		return -1;
+	}
+
+	if (starts_with(line.buf, "symref ")) {
+		strbuf_reset(referent);
+		strbuf_addstr(referent, line.buf + 7);
+		*type = REF_ISSYMREF;
+		strbuf_release(&line);
+		return 0;
+	}
+
+	/* Regular ref: line is hex oid */
+	if (get_oid_hex_any(line.buf, oid) == GIT_HASH_UNKNOWN) {
+		*failure_errno = EINVAL;
+		strbuf_release(&line);
+		return -1;
+	}
+	*type = 0;
+	strbuf_release(&line);
+	return 0;
+}
+
+static int helper_read_symbolic_ref(struct ref_store *ref_store,
+				    const char *refname,
+				    struct strbuf *referent)
+{
+	struct object_id oid;
+	unsigned int type = 0;
+	int failure_errno = 0;
+
+	if (helper_read_raw_ref(ref_store, refname, &oid, referent,
+				&type, &failure_errno))
+		return -1;
+	if (!(type & REF_ISSYMREF))
+		return -1;
+	return 0;
+}
+
+/* ---- Iterator ---- */
+
+struct helper_ref_iterator {
+	struct ref_iterator base;
+	struct helper_ref_store *refs;
+	struct strbuf line;
+	struct object_id oid;
+	char *current_refname;
+	char *current_target;
+	int done;
+};
+
+static int helper_ref_iterator_advance(struct ref_iterator *ref_iterator)
+{
+	struct helper_ref_iterator *iter =
+		(struct helper_ref_iterator *)ref_iterator;
+
+	if (iter->done)
+		return ITER_DONE;
+
+	free(iter->current_refname);
+	iter->current_refname = NULL;
+	free(iter->current_target);
+	iter->current_target = NULL;
+
+	if (ref_helper_readline(iter->refs, &iter->line) == EOF) {
+		iter->done = 1;
+		return ITER_DONE;
+	}
+
+	if (!iter->line.len) {
+		iter->done = 1;
+		return ITER_DONE;
+	}
+
+	/* Parse "<refname> <oid>" or "<refname> symref <target>" */
+	{
+		const char *p = iter->line.buf;
+		const char *sp = strchr(p, ' ');
+
+		if (!sp) {
+			iter->done = 1;
+			return ITER_ERROR;
+		}
+
+		iter->current_refname = xstrndup(p, sp - p);
+		sp++;
+
+		if (starts_with(sp, "symref ")) {
+			iter->current_target = xstrdup(sp + 7);
+			oidclr(&iter->oid, iter->refs->base.repo->hash_algo);
+			iter->base.ref.target = iter->current_target;
+		} else {
+			if (get_oid_hex_any(sp, &iter->oid) == GIT_HASH_UNKNOWN) {
+				iter->done = 1;
+				return ITER_ERROR;
+			}
+			iter->base.ref.target = NULL;
+		}
+
+		iter->base.ref.name = iter->current_refname;
+		iter->base.ref.oid = &iter->oid;
+	}
+
+	return ITER_OK;
+}
+
+static int helper_ref_iterator_seek(struct ref_iterator *ref_iterator UNUSED,
+				    const char *prefix UNUSED,
+				    unsigned int flags UNUSED)
+{
+	/* Seeking is not supported; callers should create a new iterator. */
+	return -1;
+}
+
+static void helper_ref_iterator_release(struct ref_iterator *ref_iterator)
+{
+	struct helper_ref_iterator *iter =
+		(struct helper_ref_iterator *)ref_iterator;
+	strbuf_release(&iter->line);
+	free(iter->current_refname);
+	free(iter->current_target);
+}
+
+static struct ref_iterator_vtable helper_ref_iterator_vtable = {
+	.advance = helper_ref_iterator_advance,
+	.seek = helper_ref_iterator_seek,
+	.release = helper_ref_iterator_release,
+};
+
+static struct ref_iterator *helper_ref_iterator_begin(
+		struct ref_store *ref_store,
+		const char *prefix, const char **exclude_patterns UNUSED,
+		unsigned int flags UNUSED)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct helper_ref_iterator *iter;
+
+	get_ref_helper(refs);
+
+	if (!refs->cap_list)
+		return empty_ref_iterator_begin();
+
+	CALLOC_ARRAY(iter, 1);
+	base_ref_iterator_init(&iter->base, &helper_ref_iterator_vtable);
+	iter->refs = refs;
+	strbuf_init(&iter->line, 0);
+
+	if (prefix && *prefix)
+		ref_helper_send(refs, "list %s\n", prefix);
+	else
+		ref_helper_send(refs, "list\n");
+
+	return &iter->base;
+}
+
+/* ---- Transactions ---- */
+
+static int helper_transaction_prepare(struct ref_store *ref_store,
+				      struct ref_transaction *transaction,
+				      struct strbuf *err)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct strbuf line = STRBUF_INIT;
+	int ret = 0;
+
+	get_ref_helper(refs);
+
+	if (!refs->cap_transaction) {
+		strbuf_addstr(err, "ref helper does not support transactions");
+		return -1;
+	}
+
+	ref_helper_send(refs, "transaction-begin\n");
+	if (ref_helper_readline(refs, &line) == EOF || strcmp(line.buf, "ok")) {
+		strbuf_addf(err, "ref helper transaction-begin failed: %s",
+			    line.len ? line.buf : "EOF");
+		strbuf_release(&line);
+		return -1;
+	}
+
+	for (size_t i = 0; i < transaction->nr; i++) {
+		struct ref_update *update = transaction->updates[i];
+		char new_hex[GIT_MAX_HEXSZ + 1];
+		char old_hex[GIT_MAX_HEXSZ + 1];
+
+		if (update->new_target) {
+			/* Symbolic ref creation */
+			if (update->msg && *update->msg)
+				ref_helper_send(refs,
+					"transaction-create-symref %s %s %s\n",
+					update->refname,
+					update->new_target,
+					update->msg);
+			else
+				ref_helper_send(refs,
+					"transaction-create-symref %s %s\n",
+					update->refname,
+					update->new_target);
+		} else if (update->flags & REF_HAVE_NEW &&
+			   is_null_oid(&update->new_oid)) {
+			/* Delete */
+			oid_to_hex_r(old_hex, &update->old_oid);
+			if (update->msg && *update->msg)
+				ref_helper_send(refs,
+					"transaction-delete %s %s %s\n",
+					update->refname, old_hex,
+					update->msg);
+			else
+				ref_helper_send(refs,
+					"transaction-delete %s %s\n",
+					update->refname, old_hex);
+		} else if (update->flags & REF_HAVE_OLD) {
+			/* Update with old value check */
+			oid_to_hex_r(new_hex, &update->new_oid);
+			oid_to_hex_r(old_hex, &update->old_oid);
+			if (update->msg && *update->msg)
+				ref_helper_send(refs,
+					"transaction-update %s %s %s %s\n",
+					update->refname, new_hex, old_hex,
+					update->msg);
+			else
+				ref_helper_send(refs,
+					"transaction-update %s %s %s\n",
+					update->refname, new_hex, old_hex);
+		} else {
+			/* Create (no old value check) */
+			oid_to_hex_r(new_hex, &update->new_oid);
+			if (update->msg && *update->msg)
+				ref_helper_send(refs,
+					"transaction-create %s %s %s\n",
+					update->refname, new_hex,
+					update->msg);
+			else
+				ref_helper_send(refs,
+					"transaction-create %s %s\n",
+					update->refname, new_hex);
+		}
+
+		if (ref_helper_readline(refs, &line) == EOF ||
+		    strcmp(line.buf, "ok")) {
+			strbuf_addf(err,
+				    "ref helper rejected update for '%s': %s",
+				    update->refname,
+				    line.len ? line.buf : "EOF");
+			ret = -1;
+			break;
+		}
+	}
+
+	if (!ret) {
+		ref_helper_send(refs, "transaction-prepare\n");
+		if (ref_helper_readline(refs, &line) == EOF ||
+		    strcmp(line.buf, "ok")) {
+			if (starts_with(line.buf, "error "))
+				strbuf_addstr(err, line.buf + 6);
+			else
+				strbuf_addf(err, "transaction-prepare failed: %s",
+					    line.len ? line.buf : "EOF");
+			ret = -1;
+		}
+	}
+
+	if (ret) {
+		ref_helper_send(refs, "transaction-abort\n");
+		ref_helper_readline(refs, &line);
+	}
+
+	strbuf_release(&line);
+	return ret;
+}
+
+static int helper_transaction_finish(struct ref_store *ref_store,
+				     struct ref_transaction *transaction UNUSED,
+				     struct strbuf *err)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct strbuf line = STRBUF_INIT;
+
+	ref_helper_send(refs, "transaction-finish\n");
+	if (ref_helper_readline(refs, &line) == EOF ||
+	    strcmp(line.buf, "ok")) {
+		if (starts_with(line.buf, "error "))
+			strbuf_addstr(err, line.buf + 6);
+		else
+			strbuf_addf(err, "transaction-finish failed: %s",
+				    line.len ? line.buf : "EOF");
+		strbuf_release(&line);
+		return -1;
+	}
+
+	strbuf_release(&line);
+	return 0;
+}
+
+static int helper_transaction_abort(struct ref_store *ref_store,
+				    struct ref_transaction *transaction UNUSED,
+				    struct strbuf *err UNUSED)
+{
+	struct helper_ref_store *refs = helper_downcast(ref_store);
+	struct strbuf line = STRBUF_INIT;
+
+	ref_helper_send(refs, "transaction-abort\n");
+	ref_helper_readline(refs, &line);
+	strbuf_release(&line);
+	return 0;
+}
