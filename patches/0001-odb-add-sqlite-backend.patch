From: Aaron Paterson <apaterson@pm.me>
Subject: [PATCH] odb: add SQLite object database backend

Add ODB_SOURCE_SQLITE as an alternative to ODB_SOURCE_FILES.
When the object directory path ends in ".db", use the SQLite backend
instead of the filesystem backend. This allows git repos to store
objects in a SQLite database.

The backend implements all odb_source callbacks:
  - read_object_info: SELECT type, size WHERE oid = ?
  - write_object: INSERT OR IGNORE with content-addressed dedup
  - for_each_object: iterate all rows
  - freshen_object: check existence
  - read/write alternates: not supported (returns 0/-1)
  - transactions/streams: not yet implemented

Schema: objects_loose(oid TEXT PRIMARY KEY, type INT, size INT, data BLOB)

Requires linking against libsqlite3.

Signed-off-by: Aaron Paterson <apaterson@pm.me>
---
 Makefile          |  4 ++++
 odb/source.c      | 12 ++++++++++--
 odb/source.h      |  3 +++
 3 files changed, 17 insertions(+), 2 deletions(-)

diff --git a/odb/source.h b/odb/source.h
index XXXXXXX..YYYYYYY 100644
--- a/odb/source.h
+++ b/odb/source.h
@@ -13,6 +13,9 @@ enum odb_source_type {

 	/* The "files" backend that uses loose objects and packfiles. */
 	ODB_SOURCE_FILES,
+
+	/* The "sqlite" backend that uses a SQLite database. */
+	ODB_SOURCE_SQLITE,
 };

diff --git a/odb/source.c b/odb/source.c
index XXXXXXX..YYYYYYY 100644
--- a/odb/source.c
+++ b/odb/source.c
@@ -3,12 +3,22 @@
 #include "odb/source-files.h"
 #include "odb/source.h"
 #include "packfile.h"
+#include "odb/source-sqlite.h"
+
+static int path_is_sqlite(const char *path) {
+	size_t len = strlen(path);
+	return len > 3 && !strcmp(path + len - 3, ".db");
+}

 struct odb_source *odb_source_new(struct object_database *odb,
 				  const char *path,
 				  bool local)
 {
-	return &odb_source_files_new(odb, path, local)->base;
+	if (path_is_sqlite(path))
+		return &odb_source_sqlite_new(odb, path, local)->base;
+	else
+		return &odb_source_files_new(odb, path, local)->base;
 }

diff --git a/Makefile b/Makefile
index XXXXXXX..YYYYYYY 100644
--- a/Makefile
+++ b/Makefile
@@ -XXX,6 +XXX,10 @@ LIB_OBJS += odb/source.o
 LIB_OBJS += odb/source-files.o
+LIB_OBJS += odb/source-sqlite.o
+
+EXTLIBS += -lsqlite3
