+
+void test_odb_source__format_by_name_files(void)
+{
+	cl_assert_equal_i(ODB_STORAGE_FORMAT_FILES,
+			  odb_storage_format_by_name("files"));
+}
+
+void test_odb_source__format_by_name_unknown(void)
+{
+	cl_assert_equal_i(ODB_STORAGE_FORMAT_UNKNOWN,
+			  odb_storage_format_by_name("nosuchbackend"));
+}
+
+void test_odb_source__format_to_name_files(void)
+{
+	cl_assert_equal_s("files",
+			  odb_storage_format_to_name(ODB_STORAGE_FORMAT_FILES));
+}
+
+void test_odb_source__format_to_name_unknown(void)
+{
+	cl_assert_equal_s("unknown",
+			  odb_storage_format_to_name(ODB_STORAGE_FORMAT_UNKNOWN));
+}
+
+void test_odb_source__format_to_name_out_of_range(void)
+{
+	cl_assert_equal_s("unknown",
+			  odb_storage_format_to_name(99));
+}
+
+void test_odb_source__init_populates_fields(void)
+{
+	struct odb_source src;
+	memset(&src, 0, sizeof(src));
+
+	odb_source_init(&src, NULL, ODB_STORAGE_FORMAT_FILES,
+			"/tmp/objects", 1);
+
+	cl_assert_equal_i(ODB_STORAGE_FORMAT_FILES, src.type);
+	cl_assert_equal_s("/tmp/objects", src.path);
+	cl_assert_equal_i(1, src.local);
+	cl_assert(src.odb == NULL);
+
+	free(src.path);
+}
+
+void test_odb_source__release_frees_path(void)
+{
+	struct odb_source src;
+	memset(&src, 0, sizeof(src));
+
+	odb_source_init(&src, NULL, ODB_STORAGE_FORMAT_FILES,
+			"/tmp/objects", 0);
+	cl_assert(src.path != NULL);
+
+	odb_source_release(&src);
+	/* After release, path should have been freed. Calling release
+	 * on a NULL source should be a no-op. */
+	odb_source_release(NULL);
+}
+
+void test_odb_source__free_null_is_noop(void)
+{
+	/* odb_source_free(NULL) must not crash. */
+	odb_source_free(NULL);
+}
+
+void test_odb_source__format_by_name_helper(void)
+{
+	cl_assert_equal_i(ODB_STORAGE_FORMAT_HELPER,
+			  odb_storage_format_by_name("helper"));
+}
+
+void test_odb_source__format_to_name_helper(void)
+{
+	cl_assert_equal_s("helper",
+			  odb_storage_format_to_name(ODB_STORAGE_FORMAT_HELPER));
+}
+
+void test_odb_source__try_returns_null_for_helper_type(void)
+{
+	struct odb_source src;
+	memset(&src, 0, sizeof(src));
+	src.type = ODB_STORAGE_FORMAT_HELPER;
+
+	cl_assert(odb_source_files_try(&src) == NULL);
+}
